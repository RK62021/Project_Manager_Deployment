# Server Configuration
PORT=5000
NODE_ENV=development

# Database Connection (MongoDB Atlas URI)
# Replace <username>, <password>, and <dbname> with your Atlas credentials
MONGO_URI=mongodb+srv://admin:adminpassword@cluster0.abcde.mongodb.net/projectmanager?retryWrites=true&w=majority

# JWT Token Secret Key (Change this to a strong secure string in production)
JWT_SECRET=production_ready_secret_key_987654321_!@#

# Frontend API URL (for production/Docker orchestration)
VITE_API_URL=http://localhost:5000/api
